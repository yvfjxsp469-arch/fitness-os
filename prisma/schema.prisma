// Fitness OS — Prisma Schema v2.0
// PostgreSQL (Supabase) — Production-grade single-user schema
// No compromise on training data: exercise-level tracking from day 1

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ══════════════════════════════════════
// Enums
// ══════════════════════════════════════

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum Gender {
  MALE
  FEMALE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK1
  SNACK2
}

enum WorkoutType {
  STRENGTH
  CARDIO
  REST
}

enum GoalType {
  WEIGHT
  MACRO
  HABIT
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum FoodCategory {
  STAPLE // 主食
  MEAT // 肉类
  DAIRY // 蛋奶
  VEGETABLE // 蔬菜
  FRUIT // 水果
  FAT // 油脂
  CONDIMENT // 调味
  SNACK // 零食
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  QUADS
  HAMSTRINGS
  GLUTES
  CALVES
  CORE
}

// ══════════════════════════════════════
// User & Profile
// ══════════════════════════════════════

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String   @map("display_name") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  profile           UserProfile?
  weightRecords     WeightRecord[]
  bodyMeasurements  BodyMeasurement[]
  meals             Meal[]
  workouts          Workout[]
  goals             Goal[]
  dailySummaries    DailySummary[]
  healthMetrics     HealthMetric[]
  trainingTemplates TrainingTemplate[]
  customFoods       Food[]             @relation("CustomFoods")
  customExercises   Exercise[]         @relation("CustomExercises")

  @@map("users")
}

model UserProfile {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @unique @map("user_id") @db.Uuid
  heightCm            Decimal       @map("height_cm") @db.Decimal(5, 1)
  dateOfBirth         DateTime      @map("date_of_birth") @db.Date
  gender              Gender
  activityLevel       ActivityLevel @default(SEDENTARY) @map("activity_level")
  dailyCalorieDeficit Int           @default(800) @map("daily_calorie_deficit")
  proteinRatio        Decimal       @default(0.38) @map("protein_ratio") @db.Decimal(3, 2)
  fatRatio            Decimal       @default(0.28) @map("fat_ratio") @db.Decimal(3, 2)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ══════════════════════════════════════
// Weight
// ══════════════════════════════════════

model WeightRecord {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @db.Date
  weightKg  Decimal  @map("weight_kg") @db.Decimal(5, 2)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("weight_records")
}

// ══════════════════════════════════════
// Body Measurements
// ══════════════════════════════════════

model BodyMeasurement {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @db.Date
  waistCm   Decimal? @map("waist_cm") @db.Decimal(5, 1)
  chestCm   Decimal? @map("chest_cm") @db.Decimal(5, 1)
  hipCm     Decimal? @map("hip_cm") @db.Decimal(5, 1)
  thighCm   Decimal? @map("thigh_cm") @db.Decimal(5, 1)
  armCm     Decimal? @map("arm_cm") @db.Decimal(5, 1)
  neckCm    Decimal? @map("neck_cm") @db.Decimal(5, 1)
  weightKg  Decimal? @map("weight_kg") @db.Decimal(5, 2)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("body_measurements")
}

// ══════════════════════════════════════
// Nutrition: Food
// ══════════════════════════════════════

model Food {
  id                 String       @id @default(uuid()) @db.Uuid
  name               String       @db.VarChar(100)
  category           FoodCategory
  servingSize        Decimal      @map("serving_size") @db.Decimal(6, 1)
  servingUnit        String       @map("serving_unit") @db.VarChar(10)
  caloriesPerServing Decimal      @map("calories_per_serving") @db.Decimal(6, 1)
  proteinPerServing  Decimal      @map("protein_per_serving") @db.Decimal(5, 1)
  carbsPerServing    Decimal      @map("carbs_per_serving") @db.Decimal(5, 1)
  fatPerServing      Decimal      @map("fat_per_serving") @db.Decimal(5, 1)
  fiberPerServing    Decimal?     @map("fiber_per_serving") @db.Decimal(5, 1)
  isCustom           Boolean      @default(false) @map("is_custom")
  creatorId          String?      @map("creator_id") @db.Uuid
  isDeleted          Boolean      @default(false) @map("is_deleted")
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  creator   User?      @relation("CustomFoods", fields: [creatorId], references: [id], onDelete: SetNull)
  mealFoods MealFood[]

  @@index([category, isDeleted])
  @@index([name])
  @@map("foods")
}

// ══════════════════════════════════════
// Nutrition: Meal & MealFood
// ══════════════════════════════════════

model Meal {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @db.Date
  mealType  MealType @map("meal_type")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealFoods MealFood[]

  @@unique([userId, date, mealType])
  @@index([userId, date])
  @@map("meals")
}

model MealFood {
  id       String   @id @default(uuid()) @db.Uuid
  mealId   String   @map("meal_id") @db.Uuid
  foodId   String   @map("food_id") @db.Uuid
  servings Decimal  @db.Decimal(5, 1)
  // Snapshot — values frozen at logging time
  calories Decimal  @db.Decimal(6, 1)
  protein  Decimal  @db.Decimal(5, 1)
  carbs    Decimal  @db.Decimal(5, 1)
  fat      Decimal  @db.Decimal(5, 1)
  fiber    Decimal? @db.Decimal(5, 1)

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id], onDelete: Restrict)

  @@index([mealId])
  @@map("meal_foods")
}

// ══════════════════════════════════════
// Training: Exercise Library
// ══════════════════════════════════════

model Exercise {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @db.VarChar(100)
  muscleGroup MuscleGroup @map("muscle_group")
  isCustom    Boolean     @default(false) @map("is_custom")
  creatorId   String?     @map("creator_id") @db.Uuid
  isDeleted   Boolean     @default(false) @map("is_deleted")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  creator           User?                      @relation("CustomExercises", fields: [creatorId], references: [id], onDelete: SetNull)
  workoutExercises  WorkoutExercise[]
  templateExercises TrainingTemplateExercise[]

  @@index([muscleGroup, isDeleted])
  @@index([name])
  @@map("exercises")
}

// ══════════════════════════════════════
// Training: Workout (exercise-level)
// ══════════════════════════════════════

model Workout {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  date        DateTime    @db.Date
  type        WorkoutType
  name        String      @db.VarChar(200)
  templateId  String?     @map("template_id") @db.Uuid
  durationMin Int?        @map("duration_min")
  rpe         Int?
  notes       String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template  TrainingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  exercises WorkoutExercise[]

  @@index([userId, date(sort: Desc)])
  @@map("workouts")
}

model WorkoutExercise {
  id         String  @id @default(uuid()) @db.Uuid
  workoutId  String  @map("workout_id") @db.Uuid
  exerciseId String  @map("exercise_id") @db.Uuid
  order      Int
  notes      String? @db.Text

  workout  Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  sets     ExerciseSet[]

  @@index([workoutId])
  @@map("workout_exercises")
}

model ExerciseSet {
  id                String   @id @default(uuid()) @db.Uuid
  workoutExerciseId String   @map("workout_exercise_id") @db.Uuid
  setNumber         Int      @map("set_number")
  weightKg          Decimal? @map("weight_kg") @db.Decimal(6, 1)
  reps              Int?
  durationSec       Int?     @map("duration_sec")
  distanceM         Decimal? @map("distance_m") @db.Decimal(6, 1)
  rpe               Int?
  isWarmup          Boolean  @default(false) @map("is_warmup")
  notes             String?  @db.Text

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId])
  @@map("exercise_sets")
}

// ══════════════════════════════════════
// Training: Templates
// ══════════════════════════════════════

model TrainingTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises TrainingTemplateExercise[]
  workouts  Workout[]

  @@map("training_templates")
}

model TrainingTemplateExercise {
  id         String  @id @default(uuid()) @db.Uuid
  templateId String  @map("template_id") @db.Uuid
  exerciseId String  @map("exercise_id") @db.Uuid
  order      Int
  notes      String? @db.Text

  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([templateId])
  @@map("training_template_exercises")
}

// ══════════════════════════════════════
// Goals & Milestones
// ══════════════════════════════════════

model Goal {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  type        GoalType
  title       String     @db.VarChar(200)
  description String?    @db.Text
  targetValue Decimal    @map("target_value") @db.Decimal(8, 2)
  startValue  Decimal    @map("start_value") @db.Decimal(8, 2)
  unit        String     @db.VarChar(20)
  startDate   DateTime   @map("start_date") @db.Date
  targetDate  DateTime?  @map("target_date") @db.Date
  status      GoalStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress   GoalProgress[]
  milestones GoalMilestone[]

  @@map("goals")
}

model GoalProgress {
  id           String   @id @default(uuid()) @db.Uuid
  goalId       String   @map("goal_id") @db.Uuid
  date         DateTime @db.Date
  currentValue Decimal  @map("current_value") @db.Decimal(8, 2)
  percentage   Decimal  @db.Decimal(5, 1)

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, date])
  @@index([goalId, date(sort: Desc)])
  @@map("goal_progresses")
}

model GoalMilestone {
  id          String    @id @default(uuid()) @db.Uuid
  goalId      String    @map("goal_id") @db.Uuid
  title       String    @db.VarChar(100)
  targetValue Decimal   @map("target_value") @db.Decimal(8, 2)
  achieved    Boolean   @default(false)
  achievedAt  DateTime? @map("achieved_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_milestones")
}

// ══════════════════════════════════════
// Daily Summary (computed cache)
// ══════════════════════════════════════

model DailySummary {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  date           DateTime @db.Date
  weightKg       Decimal? @map("weight_kg") @db.Decimal(5, 2)
  totalCalories  Int?     @map("total_calories")
  totalProtein   Decimal? @map("total_protein") @db.Decimal(5, 1)
  totalCarbs     Decimal? @map("total_carbs") @db.Decimal(5, 1)
  totalFat       Decimal? @map("total_fat") @db.Decimal(5, 1)
  totalFiber     Decimal? @map("total_fiber") @db.Decimal(5, 1)
  workoutCount   Int      @default(0) @map("workout_count")
  workoutMinutes Int?     @map("workout_minutes")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_summaries")
}

// ══════════════════════════════════════
// Apple Watch / HealthKit (v1.3 future)
// ══════════════════════════════════════

model HealthMetric {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  date       DateTime @db.Date
  source     String   @default("manual") @db.VarChar(50)
  metricType String   @map("metric_type") @db.VarChar(50)
  value      Decimal  @db.Decimal(10, 1)
  unit       String   @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date(sort: Desc)])
  @@index([userId, metricType, date(sort: Desc)])
  @@map("health_metrics")
}
